# ============================================
# DeepResearch 生产环境配置
# ============================================

# API 密钥配置（必须设置！多个用逗号分隔）
# DEEPRESEARCH_API_KEYS=your-production-secret-key-1,your-production-secret-key-2
DEEPRESEARCH_API_KEYS=

# 服务端配置
DEEPRESEARCH_HOST=0.0.0.0
DEEPRESEARCH_PORT=8000

# 日志配置
DEEPRESEARCH_LOG_LEVEL=INFO
DEEPRESEARCH_LOG_FILE=/app/logs/deepresearch.log

# 任务配置
DEEPRESEARCH_MAX_CONCURRENT_TASKS=3
DEEPRESEARCH_TASK_TIMEOUT=3600

# LLM 配置目录
DEEPRESEARCH_CONFIG_DIR=/app/config
