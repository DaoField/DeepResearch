# ============================================
# DeepResearch 开发环境配置
# ============================================

# API 密钥配置（多个用逗号分隔）
# DEEPRESEARCH_API_KEYS=your-secret-key-1,your-secret-key-2
# 留空表示不启用认证（仅开发环境建议）
DEEPRESEARCH_API_KEYS=

# 服务端配置
DEEPRESEARCH_HOST=0.0.0.0
DEEPRESEARCH_PORT=8000

# 日志配置
DEEPRESEARCH_LOG_LEVEL=DEBUG
# DEEPRESEARCH_LOG_FILE=/app/logs/deepresearch.log

# 任务配置
DEEPRESEARCH_MAX_CONCURRENT_TASKS=5
DEEPRESEARCH_TASK_TIMEOUT=3600

# LLM 配置目录
DEEPRESEARCH_CONFIG_DIR=/app/config
